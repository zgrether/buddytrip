# BuddyTrip — Environment Variables
# Copy to .env.local and fill in your values.

# Supabase project URL (public, safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable key (public, safe for client — RLS enforced)
# New format: sb_publishable_... (legacy eyJ... keys are deprecated)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase secret key (SECRET — server-only, bypasses RLS)
# Required for integration tests (global-setup creates shared test users)
# New format: sb_secret_... (legacy eyJ... keys are deprecated)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Anthropic API key (SECRET — server-only, used for AI destination suggestions)
ANTHROPIC_API_KEY=sk-ant-...

# --- CI-only (set as GitHub Actions secrets) ---

# Supabase DB connection string for `supabase db push` in CI
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=postgresql://...
