# BuddyTrip — Environment Variables
# Copy to .env.local and fill in your values:  cp .env.example .env.local
# .env.local is gitignored. See README.md for the full setup walkthrough.

# ── Supabase (local dev + tests) ─────────────────────────────────────────────
# LOCAL DEV & TESTS run against a LOCAL Supabase stack, not prod. Start it with
# `npx supabase start` (needs Docker running), which applies the migrations and prints
# your local URL + keys. Get the exact values for the two keys below any time with:
#     npx supabase status -o env
# and map:  ANON_KEY → NEXT_PUBLIC_SUPABASE_ANON_KEY,  SERVICE_ROLE_KEY → SUPABASE_SERVICE_ROLE_KEY.
# Do NOT hardcode a "known" local key — it is NOT constant across machines / CLI versions
# (recent CLIs issue sb_publishable_ / sb_secret_ keys, older ones legacy eyJ… JWTs), so
# always paste YOUR stack's values. Only the URL is stable. Point at the remote/prod
# project solely when you deliberately need prod data (discouraged).

# Public, safe for client. Local stack (port is fixed by supabase/config.toml):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Public anon key (RLS enforced) — paste ANON_KEY from `npx supabase status -o env`:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server-only, bypasses RLS. Required for the test suite (global-setup creates
# the shared test users). Paste SERVICE_ROLE_KEY from `npx supabase status -o env`:
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
# Canonical site origin (no trailing slash). Local dev = http://localhost:3000.
# Drives email invite/trip links, the tRPC base URL, and OG metadataBase (src/app/layout.tsx).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google OAuth (OPTIONAL locally) ──────────────────────────────────────────
# Consumed by supabase/config.toml [auth.external.google] to enable the "Sign in with
# Google" button on the LOCAL stack. `supabase start` boots fine without them, and the
# app also supports email/password signup at /login — so set these only if you want to
# exercise Google sign-in locally. Values come from the Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional feature keys (server-only; features degrade gracefully if unset) ──
# golfcourseapi.com — golf course search + scorecard data (src/app/api/golf-courses).
# Free tier 50 req/day; local-first search + a daily counter protect it. Unset →
# search returns [] and the UI falls back to manual course entry.
GOLFCOURSE_API_KEY=

# Google Places — LOCATION autocomplete via /api/places (src/app/api/places/route.ts).
# Needs "Places API (New)" with billing. Unset → /api/places returns 503 and the
# location field shows "search unavailable". Must be set in the deployed (Vercel) env.
GOOGLE_PLACES_API_KEY=

# ── Email (Resend; src/lib/email.ts) ─────────────────────────────────────────
# Resend API key (SECRET). Sends trip invites + beta feedback. Unset → email is skipped.
RESEND_API_KEY=

# Sender identity. Must be an address on a Resend-verified domain or sends fail / spam.
# Unset → falls back to Resend's sandbox sender (delivers only to the account owner).
RESEND_FROM=BuddyTrip <noreply@bbmi.app>

# Dev-only: redirect ALL app email to this address so you never email real users while
# testing. Ignored in production.
RESEND_DEV_TO_EMAIL=

# Destination for in-app beta feedback. Set in prod/preview; omit in CI/local.
FEEDBACK_TO_EMAIL=

# ── CI / prod migration push (not needed for local dev) ──────────────────────
# Post-Step-0, CI runs against a local `supabase start` stack and no longer reads any
# of the above from secrets. SUPABASE_DB_URL is used only for a manual
# `supabase db push --linked` of migrations to the prod project (see CONTRIBUTING.md).
# SUPABASE_DB_URL=postgresql://...
